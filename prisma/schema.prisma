generator client {
  provider = "prisma-client-js"
}

// Supabase: set DATABASE_URL to your Postgres URI (Settings → Database → URI).
// Use the direct connection (port 5432) unless you know you need the pooler + split URLs.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteImage {
  slotId    String   @id
  url       String
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Event {
  id        String   @id @default(cuid())
  title     String
  date      String
  location  String
  imageUrl  String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  paymentMethod String
  firstName     String
  lastName      String
  email         String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  region        String?
  postalCode    String
  country       String
  lines         OrderLine[]
}

model OrderLine {
  id           String @id @default(cuid())
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  packageId    String
  packageCode  String
  packageName  String
  rvPerUnit    Int
  quantity     Int
}
