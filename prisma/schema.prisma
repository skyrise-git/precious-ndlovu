generator client {
  provider = "prisma-client-js"
}

// Supabase: use the pooled URL for DATABASE_URL (port 6543, PgBouncer) in production.
// Use DIRECT_URL (direct Postgres, port 5432) for migrations — see .env.example.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SiteImage {
  slotId    String   @id
  url       String
  updatedAt DateTime @updatedAt
}
