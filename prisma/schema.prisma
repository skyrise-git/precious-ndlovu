generator client {
  provider = "prisma-client-js"
}

// Supabase: set DATABASE_URL to your Postgres URI (Settings → Database → URI).
// Use the direct connection (port 5432) unless you know you need the pooler + split URLs.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteImage {
  slotId    String   @id
  url       String
  updatedAt DateTime @updatedAt
}
