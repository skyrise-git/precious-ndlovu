# --- Supabase (PostgreSQL) + Prisma ---
#
# 1) Supabase → Project Settings → Database → copy the "URI" (direct Postgres, port 5432).
# 2) Paste into DATABASE_URL below and in Vercel → Environment Variables.
# 3) Run migrations: npm run db:migrate (or prisma migrate resolve if you applied SQL manually).

DATABASE_URL=""

# Admin session signing (min 16 characters)
AUTH_SECRET="replace-with-a-long-random-string"

# Single site owner password (plain text comparison with timing-safe equal)
ADMIN_PASSWORD="replace-me"

# Public URL for metadata / OG. Use https:// in production (e.g. https://yoursite.com) — not http://.
# Local:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# WhatsApp chat: digits only, country code, no +. Must be YOUR number — do not copy a random "example" value. If unset, the admin "Phone" number is used. Powers the green floating button + links in the top bar and contact section. After changing, rebuild/redeploy (NEXT_PUBLIC_ is read at build time).
# NEXT_PUBLIC_WHATSAPP=27834111626
# Optional: prefilled message in the WhatsApp chat link (?text=). If unset, a default greeting is used.
# NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi Precious, I visited your website and would like to learn more about your offerings.

# Optional: Resend for contact form emails
# RESEND_API_KEY=
# RESEND_FROM="Precious Ndlovu <onboarding@resend.dev>"
# CONTACT_TO_EMAIL=you@example.com
# Optional: route shop order notifications here instead of CONTACT_TO_EMAIL
# ORDER_TO_EMAIL=

# UploadThing — for admin image uploads (get token from uploadthing.com dashboard)
UPLOADTHING_TOKEN=""
