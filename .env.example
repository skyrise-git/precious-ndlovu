# --- Supabase (PostgreSQL) + Prisma ---
#
# 1) Create a project at https://supabase.com
# 2) Project Settings → Database → Connection string
#    - Mode "Transaction pooler" (port 6543) → paste into DATABASE_URL (best for Vercel / serverless).
#    - Mode "Session" or "Direct" (port 5432) → paste into DIRECT_URL (required for migrations).
# 3) Copy the same values into Vercel → Project → Settings → Environment Variables.
# 4) After changing schema: run `npm run db:migrate:dev` locally, commit migrations, deploy.
# 5) On Vercel, set build command to: prisma migrate deploy && next build
#    (or run `npm run db:migrate` in a CI step before deploy).
#
# Simpler local-only: set DATABASE_URL and DIRECT_URL to the same "URI" (direct, port 5432).
#
# Example shapes (your host/password will differ):
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres"

DATABASE_URL=""
DIRECT_URL=""

# Admin session signing (min 16 characters)
AUTH_SECRET="replace-with-a-long-random-string"

# Single site owner password (plain text comparison with timing-safe equal)
ADMIN_PASSWORD="replace-me"

# Public URL for metadata / OG (production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Resend for contact form emails
# RESEND_API_KEY=
# RESEND_FROM="Precious Ndlovu <onboarding@resend.dev>"
# CONTACT_TO_EMAIL=you@example.com

# Optional: Vercel Blob for admin image uploads
# BLOB_READ_WRITE_TOKEN=
